# Docker Hub image namespace.
DOCKERHUB_NAMESPACE=weammakhoul

# Image tags. GitHub Actions updates these on EC2 during deploy.
YOLO_IMAGE_TAG=0.0.1
AGENT_IMAGE_TAG=0.0.1
FRONTEND_IMAGE_TAG=0.0.1

# Fluent Bit sends local/dev logs here by default.
FLUENT_BIT_S3_BUCKET=weam-polyai-logs-dev
AWS_REGION=us-east-1

# Local:
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# Dev EC2:
# NEXT_PUBLIC_AGENT_URL=http://dev.weam.fursa.click:8000

# Prod EC2 uses this value instead:
# NEXT_PUBLIC_AGENT_URL=http://prod.weam.fursa.click:8000
